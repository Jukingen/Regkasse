{
  "name": "registrierkasse-admin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node ./scripts/rm-next-cache.mjs && next dev",
    "build": "next build",
    "analyze": "cross-env ANALYZE=true NEXT_PUBLIC_RKSV_ENVIRONMENT=TEST next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:contract": "vitest run src/shared/contract src/shared/__tests__ src/features/invoices/utils/__tests__/invoiceListSort.test.ts src/api/__tests__/generatedAdminPaymentsClientSmoke.test.ts",
    "test:truth-surfaces": "vitest run src/shared/__tests__/adminTruthSurfaces.package.test.ts src/shared/__tests__/adminTruthFacets.test.ts src/shared/__tests__/truthSurfaceBehavior.test.ts src/shared/__tests__/investigationNavigation.test.ts src/shared/utils/__tests__/registerIdentity.test.ts src/shared/__tests__/foReconciliationRowTriage.test.ts src/shared/__tests__/finanzOnlineReconciliationTruth.test.ts src/shared/__tests__/adminTruthBadge.semantic.test.tsx src/shared/__tests__/rksvAdminTruth.test.ts src/shared/__tests__/adminTruthBadges.test.ts src/shared/__tests__/verificationsAuditView.test.ts",
    "test:operator-copy-locale-parity": "vitest run src/shared/__tests__/operatorCopyDeLocaleParity.test.ts",
    "test:watch": "vitest",
    "generate:api": "orval",
    "verify:api-client": "node ../scripts/verify-api-client.mjs",
    "i18n:export-csv": "node ../localization/scripts/export-translations.mjs --app frontend-admin",
    "i18n:import-csv": "node ../localization/scripts/import-translations.mjs --app frontend-admin",
    "i18n:validate": "node ../localization/scripts/validate-translations.mjs --app frontend-admin",
    "i18n:validate:ci": "node ../localization/scripts/validate-translations.mjs --app frontend-admin --strictMissing true --orphanPolicy error",
    "i18n:boundary": "node ../localization/scripts/check-translation-boundary.mjs --app frontend-admin",
    "i18n:usage": "node ../localization/scripts/check-localization-usage.mjs --app frontend-admin",
    "i18n:usage:ci": "node ../localization/scripts/check-localization-usage.mjs --app frontend-admin --strictMissing true --budgetFile ../localization/i18n-ci-budgets.json",
    "i18n:keys": "node scripts/generate-translation-key-union.mjs",
    "i18n:keys:check": "node scripts/generate-translation-key-union.mjs && git diff --quiet -- src/i18n/generated/translationKeys.ts",
    "i18n:ci": "npm run i18n:validate:ci && npm run i18n:boundary && npm run i18n:usage:ci && npm run i18n:keys:check"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@microsoft/signalr": "^10.0.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "antd": "^6.4.3",
    "axios": "^1.16.1",
    "dayjs": "^1.11.21",
    "fuse.js": "^7.4.0",
    "jszip": "^3.10.1",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@csstools/postcss-global-data": "^4.0.0",
    "@next/bundle-analyzer": "^16.2.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^28.1.0",
    "orval": "^6.24.0",
    "postcss-custom-media": "^12.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
