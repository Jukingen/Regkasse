# Keep the build context small and free of secrets / local artifacts.
# Root and package .gitignore already exclude many of these; list them here
# so Docker never sends them to the daemon.

node_modules
.next
out
build
dist
coverage
.nyc_output

# Local env / secrets (NEXT_PUBLIC_* must be passed as build-args instead)
.env
.env.*
!.env.example

# Tooling / tests
playwright-report
test-results
blob-report
playwright/.cache
*.tsbuildinfo
.eslintcache
.stylelintcache
.cache
.temp
.tmp

# VCS / IDE / deploy CLI
.git
.github
.vscode
.idea
.vercel
.netlify

# Docs & reports (not needed in image)
*.md
!README.md
FIX_REPORT*.md
ROLE_*.md
USER_ROLE_*.md
docs

# Misc
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
Dockerfile*
docker-compose*.yml
.dockerignore
