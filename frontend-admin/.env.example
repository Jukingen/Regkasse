# Copy this file to `.env.local` in THIS folder: frontend-admin/ (next to package.json & next.config.mjs).
# Do NOT put admin env only at the repository root — Next.js will not load it for this app.
#
# NEXT_PUBLIC_* — build-time (not runtime-only):
# These values are inlined into the client JS when you run `next dev` or `next build`.
# They MUST be set before that compile step. Injecting them only at `next start`, Docker run,
# or K8s pod env AFTER the image was built will NOT update the browser bundle → RKSV UI can stay UNCONFIGURED.
#
# Backend API Base URL (without trailing /api if your swagger paths include it)
# Example: http://localhost:5184
NEXT_PUBLIC_API_BASE_URL=http://localhost:5184

# Production impersonation redirect: tenant FA host base domain (default regkasse.at).
# NEXT_PUBLIC_TENANT_APP_BASE_DOMAIN=regkasse.at

# Demo import summary: optional POS open link ({slug} = tenant slug). Dev defaults to http://localhost:8081.
# NEXT_PUBLIC_POS_APP_URL=http://localhost:8081

# Development: default tenant slug when not using header switcher / localStorage dev_tenant_id.
# NEXT_PUBLIC_DEV_TENANT_ID=dev
#
# Production impersonation redirect base domain (default: regkasse.at → https://{slug}.regkasse.at).
# NEXT_PUBLIC_TENANT_APP_BASE_DOMAIN=regkasse.at
#
# Multi-tenant local testing (optional hosts file on Windows: C:\Windows\System32\drivers\etc\hosts):
#   127.0.0.1 admin.regkasse.local
#   127.0.0.1 dev.regkasse.local
#   127.0.0.1 cafe.regkasse.local
#   127.0.0.1 bar.regkasse.local
# Super Admin FA (platform host): http://admin.regkasse.local:3000  (Next.js dev default port 3000)
# Tenant FA via hosts:            http://cafe.regkasse.local:3000
# Backend dev CORS allows *.regkasse.local and *.local.
# Separate browser profiles give isolated localStorage; dropdown in header overrides per profile.

# --- RKSV / FinanzOnline (Next.js public, baked in at build) ---
# NEXT_PUBLIC_RKSV_ENVIRONMENT — allowed: TEST | PROD (case-insensitive)
# Why: visible label on /rksv so operators don't confuse FinanzOnline test vs production.
# Build: required for `npm run build`. Dev: if missing, /rksv shows UNCONFIGURED + one console.warn.
#
# Common mistakes (do not copy as-is):
# - RKSV_ENVIRONMENT=TEST   → wrong name; must be NEXT_PUBLIC_RKSV_ENVIRONMENT
# - .env.local only at repo root Regkasse/ → Next.js admin app ignores it; file must be here in frontend-admin/
NEXT_PUBLIC_RKSV_ENVIRONMENT=TEST

# Backup & DR admin: client-side pipeline step estimation (legacy). Only when set exactly to "true".
# Unset or any other value: only official server `pipeline` projection is shown; if missing, stepper stays empty with a notice.
# NEXT_PUBLIC_BACKUP_PIPELINE_CLIENT_FALLBACK=true

# Products admin: Lager column, stock action button, and low-stock tags on /products.
# Unset or true: show (backward compatible). false | 0 | no | off: hide. Baked at build (NEXT_PUBLIC_*).
# NEXT_PUBLIC_ADMIN_PRODUCTS_SHOW_LAGER=false

# Admin sidebar + /inventory page: Lager & Bestände module. When false: menu entry hidden, /inventory shows info only (no inventory API queries).
# Unset or true: show (backward compatible).
# NEXT_PUBLIC_ADMIN_SHOW_INVENTORY_NAV=false
#
# Rollout “no Lager”: set API Inventory__EnforceStockAvailability=false plus the two NEXT_PUBLIC_* above false, then rebuild admin + restart API. See docs/inventory-lager-optional.md
