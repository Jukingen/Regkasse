# Package-local ignores for frontend-admin.
# Root `.gitignore` already covers: node_modules/, .next/, dist/, coverage/,
# .env* / *.local, *.log, *.tsbuildinfo, .vercel/, .netlify/, IDE junk, etc.
# Keep only artifacts that are specific to this package’s tooling.

# Playwright E2E
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Coverage tooling extras (root covers coverage/)
.nyc_output

# Tooling caches
.cache
.eslintcache
.stylelintcache
.temp
.tmp
