{
    "JwtSettings": {
        "Issuer": "KasseAPI",
        "Audience": "KasseAPIUsers",
        "ExpirationHours": 24
    },
    "CompanyProfile": {
        "CompanyName": "Regkasse Demo GmbH",
        "TaxNumber": "ATU12345678",
        "Street": "Musterstraße 123",
        "ZipCode": "1010",
        "City": "Wien",
        "Country": "AT",
        "PhoneNumber": "+43 1 234 567",
        "Email": "info@regkasse.at",
        "Website": "www.regkasse.at",
        "FooterText": "Es bediente Sie unser Team. Danke für Ihren Einkauf!",
        "LogoUrl": "https://via.placeholder.com/150",
        "DefaultKassenId": "KASSE-001"
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore": "Information"
        }
    },
    "Auth": {
        "AllowLegacyLoginWithoutClientApp": false,
        "RequireTenantMembershipForLogin": false
    },
    "AllowedHosts": "*",
    "Tse": {
        "TseMode": "Device",
        "Mode": "Real"
    },
    "AuditRetention": {
        "RetentionYears": 7
    },
    "OfflineReplay": {
        "MaxLockWaitMs": 10000,
        "LockRetryIntervalMs": 100
    },
    "PayloadHashGuard": {
        "MismatchWarningThresholdPercent": 10,
        "SampleSizeForExportCheck": 500,
        "RunStartupCheck": false
    },
    "PayloadHashRepairJob": {
        "Enabled": true,
        "Interval": "01:00:00",
        "BatchSizePerCycle": 500,
        "MaxBatchesPerCycle": 10,
        "CompletionSampleSize": 5000
    },
    "FinanzOnlineRetryJob": {
        "Enabled": true,
        "Interval": "00:02:00",
        "MaxRetryCount": 5,
        "BaseDelaySeconds": 60,
        "BackoffCapSeconds": 3600,
        "BatchSize": 50,
        "AlertFailedThreshold": 10,
        "RegisterRepeatedFailureThreshold": 3
    },
    "FinanzOnline": {
        "Simulation": {
            "Scenario": "None",
            "RetryCountBeforeSuccess": 2,
            "ProtocolPendingQueriesBeforeSuccess": 2,
            "FixedDelayMs": 0,
            "Seed": 0,
            "EnableScenarioOutsideDevelopment": false,
            "Developer": {
                "BehaviorProfile": "None",
                "EnableBehaviorProfilesOutsideDevelopment": false,
                "RetryableSubmitFailuresBeforeSuccess": 2,
                "ProtocolPendingQueriesBeforeSuccess": 2,
                "ArtificialLatencyMs": 0
            }
        }
    },
    "CoverageGuard": {
        "LowCoverageThresholdPercent": 80,
        "MinSamplesForAlert": 10,
        "WriteAlertToAuditLog": true
    },
    "PosCashRegisterFeatures": {
        "EffectiveDefaultOnPosEntry": true,
        "AutoOpenSoleClosedRegister": false,
        "AutoOpenAssignedClosedRegister": false,
        "DefaultAutoOpenOpeningBalance": 0
    },
    "Inventory": {
        "EnforceStockAvailability": true
    }
}
