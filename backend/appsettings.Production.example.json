{
  "Auth": {
    "AllowLegacyLoginWithoutClientApp": false,
    "RequireTenantMembershipForLogin": true
  },
  "SessionPolicy": {
    "MaxConcurrentSessions": 1,
    "SessionTimeoutMinutes": 30,
    "AllowMultipleDevices": false
  },
  "DownloadSecurity": {
    "MaxDownloadsPerUserPerDay": 50,
    "MaxFileSizeBytes": 2147483648,
    "DownloadLinkTtlHours": 24,
    "RequireApprovalForSensitiveExports": true,
    "RequireTwoFactorForCriticalExports": true,
    "SuperAdminMaySelfApprove": true
  },
  "TwoFactorAuth": {
    "Enabled": true,
    "BypassInDevelopment": false,
    "TestToken": ""
  },
  "RateLimiting": {
    "Enabled": true,
    "Limit": 100,
    "WindowSeconds": 60
  },
  "AccountLockout": {
    "Enabled": true,
    "MaxAttempts": 5,
    "LockoutMinutes": 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Error",
      "Microsoft.AspNetCore": "Error",
      "Microsoft.EntityFrameworkCore": "Error",
      "KasseAPI_Final": "Warning"
    }
  },
  "RKSV": {
    "Mode": "Production",
    "TseMode": "Real",
    "FinanzOnlineMode": "Real",
    "ShowDemoLabel": false
  },
  "Tse": {
    "TseMode": "Device",
    "Mode": "Real"
  },
  "Fiskaly": {
    "ApiKey": "",
    "ApiSecret": "",
    "TseSerialNumber": "",
    "ApiBaseUrl": "https://api.fiskaly.com/v1"
  },
  "FinanzOnline": {
    "Mode": "Production",
    "Session": {
      "UseSimulation": false,
      "BaseUrl": "https://finanzonline.bmf.gv.at/fonws/ws/session"
    },
    "Registrierkassen": {
      "UseSimulation": false
    },
    "TransmissionQuery": {
      "UseSimulation": false
    },
    "RksvSubmission": {
      "ClientKind": "Real",
      "Enabled": true
    }
  },
  "FinanzOnlineOutbox": {
    "Enabled": true
  },
  "FinanzOnlineRetryJob": {
    "Enabled": true
  },
  "Elmah": {
    "ApplicationName": "Regkasse",
    "LogLevel": "Error",
    "MaxLogEntries": 5000,
    "RetentionCheckIntervalMinutes": 60
  },
  "Backup": {
    "ExecutionAdapterKind": "PgDump",
    "ArtifactStagingRoot": "/var/backups/regkasse/staging",
    "ExternalArchiveRoot": "/var/backups/regkasse/archive",
    "ExternalArchiveMutableTargetAccepted": true,
    "PgDumpExecutablePath": "/usr/bin/pg_dump",
    "LogicalDumpConnectionStringName": "DefaultConnection",
    "WorkerEnabled": true,
    "AcknowledgePhase1NoRealBackup": false,
    "ScheduledBackupEnabled": true,
    "ScheduledBackupCron": "0 2 * * *",
    "RetentionPolicyMode": "ReportOnly",
    "ArtifactRetentionDays": 30
  },
  "JwtSettings": {
    "Issuer": "KasseAPI",
    "Audience": "KasseAPIUsers",
    "ExpirationHours": 24
  },
  "Cors": {
    "AllowedOrigins": [
      "https://pos.regkasse.at",
      "https://admin.regkasse.at",
      "https://www.regkasse.at"
    ]
  },
  "AllowedHosts": "api.regkasse.at;admin.regkasse.at;pos.regkasse.at;regkasse.at;*.regkasse.at",
  "Redis": {
    "ConnectionString": "redis-cluster:6379",
    "InstanceName": "Regkasse_Prod"
  },
  "Security": {
    "Csrf": {
      "Enabled": true,
      "BypassInDevelopment": false,
      "HeaderName": "X-XSRF-TOKEN",
      "CookieName": "XSRF-TOKEN",
      "TokenLifetimeHours": 24
    }
  },
  "Monitoring": {
    "Enabled": true,
    "MetricsEndpoint": "/metrics",
    "Prometheus": {
      "Enabled": true,
      "ScrapeIntervalSeconds": 15
    }
  }
}
