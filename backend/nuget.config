<?xml version="1.0" encoding="utf-8"?>
<!--
  Deterministic NuGet restore for the backend API + tests.
  <clear /> drops machine/user feeds so CI and local use the same sources.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <!-- Single public feed: map all package ids to nuget.org (dependency-confusion guard). -->
  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
