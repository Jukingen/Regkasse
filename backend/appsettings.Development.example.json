      "Microsoft.EntityFrameworkCore": "Warning",
      "KasseAPI_Final": "Information",
      "KasseAPI_Final.Services.LicenseService": "Error"
    }
  },
  "Auth": {
    "AllowLegacyLoginWithoutClientApp": false,
