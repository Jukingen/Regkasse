    "CleanupIntervalMinutes": 1440,
    "CleanupEnabled": true
  },
  "DownloadSecurity": {
    "MaxDownloadsPerUserPerDay": 50,
    "MaxFileSizeBytes": 2147483648,
    "DownloadLinkTtlHours": 24,
    "RequireApprovalForSensitiveExports": true,
    "RequireTwoFactorForCriticalExports": true,
    "SuperAdminMaySelfApprove": true
  },
  "CriticalActions": {
    "Enabled": false,
    "BypassInDevelopment": true,
    "ApprovalTokenTtlMinutes": 5,
    "PendingRequestTtlMinutes": 30,
    "SuperAdminMaySelfApprove": true
  },
  "TenantOperationLimits": {
    "Enabled": false,
    "BypassInDevelopment": true,
    "MaxBulkDeletePerDay": 50,
    "MaxPriceUpdatePerHour": 100,
    "MaxProductCreatePerDay": 500,
    "MaxUserCreatePerDay": 20,
    "MaxBackupPerDay": 5,
    "MaxExportPerDay": 10,
    "RequireApprovalForBulkDelete": 500,
    "RequireApprovalForPriceUpdate": 200
