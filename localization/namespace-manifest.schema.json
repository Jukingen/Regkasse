{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://regkasse.local/schemas/localization/namespace-manifest.schema.json",
  "type": "object",
  "required": [
    "version",
    "defaultLocale",
    "locales",
    "reservedPrefixes",
    "keyPattern",
    "apps"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "defaultLocale": {
      "type": "string",
      "minLength": 2
    },
    "locales": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "reservedPrefixes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "keyPattern": {
      "type": "string",
      "minLength": 3
    },
    "apps": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "localesDir",
          "csvPath",
          "namespaces"
        ],
        "properties": {
          "localesDir": {
            "type": "string",
            "minLength": 1
          },
          "csvPath": {
            "type": "string",
            "minLength": 1
          },
          "namespaces": {
            "type": "array",
            "minItems": 0,
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_\\-]*$"
            },
            "uniqueItems": true
          },
          "deferred": {
            "type": "boolean",
            "description": "When true, validation/export/usage scripts skip this app (no locale catalog yet)."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
