# Copy to `.env` in the repository root (docker compose loads it automatically).
#   cp .env.example .env
# Do not commit `.env` — it may contain local secrets.

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kasse_db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379
REDIS_INSTANCE_NAME=Regkasse_Docker

# --- Backend ---
API_PORT=5184
ASPNETCORE_ENVIRONMENT=Development
# Min 32 characters — replace before sharing the compose stack
JWT_SECRET_KEY=CHANGE_ME_DOCKER_DEV_JWT_SECRET_KEY_32CHARS_MIN
JWT_ISSUER=Regkasse
JWT_AUDIENCE=RegkasseClients
TWO_FACTOR_ENABLED=false
CSRF_ENABLED=false

# --- Frontend Admin (build-time; rebuild image after changing) ---
ADMIN_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5184
NEXT_PUBLIC_RKSV_ENVIRONMENT=TEST
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# NEXT_PUBLIC_SENTRY_RELEASE=

# --- POS web (optional profile: docker compose --profile pos up --build) ---
POS_PORT=8081
EXPO_PUBLIC_API_BASE_URL=http://localhost:5184/api
EXPO_PUBLIC_DEV_TENANT_ID=dev
EXPO_PUBLIC_ADMIN_BASE_URL=http://localhost:3000
