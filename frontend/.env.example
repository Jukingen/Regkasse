# POS frontend API base URL for Expo public config.
# Native/device beta builds must point to a backend URL reachable from the device.
EXPO_PUBLIC_API_BASE_URL=http://localhost:5184/api

# Development: tenant slug for ?tenant= and X-Tenant-Id (defaults to "dev" when unset in __DEV__).
# Must match tenants.slug (seed: dev, cafe, bar). Legacy test_cafe/test_bar map to cafe/bar.
# EXPO_PUBLIC_DEV_TENANT_ID=cafe

# Optional: artificial HTTP delay in dev only (__DEV__ + non-production NODE_ENV). Metro restart after .env changes.
EXPO_PUBLIC_SIMULATE_NETWORK_DELAY_MS=0

# Offline / TSE / NTP POS simulations (EXPO_PUBLIC_SIMULATE_OFFLINE_MODE, EXPO_PUBLIC_SIMULATE_POS_* , etc.)
# are permanently disabled in app code — do not rely on these env vars; they are ignored.

# Optional: full URL to open when the user taps “Lizenz verlängern” (e.g. FA license page).
# If unset, EXPO_PUBLIC_ADMIN_BASE_URL + /admin/license is used when EXPO_PUBLIC_ADMIN_BASE_URL is set.
# EXPO_PUBLIC_LICENSE_EXTENSION_URL=https://admin.example.com/admin/license

# Optional: admin base URL for license extension (Option B). Trailing slash is optional.
# EXPO_PUBLIC_ADMIN_BASE_URL=https://admin.example.com
