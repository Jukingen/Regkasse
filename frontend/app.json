{
  "expo": {
    "name": "Cash Register",
    "slug": "cash-register",
    "version": "1.0.0",
    "sdkVersion": "56.0.0",
    "runtimeVersion": "56.0.0",
    "orientation": "portrait",
    "scheme": "cashregister",
    "userInterfaceStyle": "automatic",
    "description": "RKSV Compliant Cash Register for Cashiers",
    "icon": "./assets/images/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.registrierkasse.cashregister",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "192.168.1.2": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "192.168.1.100": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "192.168.0.100": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "10.0.0.100": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "172.20.10.1": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.registrierkasse.cashregister"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-mail-composer",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/OCRA-B.ttf"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Kamera wird für Kunden-QR und Gutschein-Scan benötigt."
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
