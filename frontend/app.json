{
  "expo": {
    "name": "Cash Register",
    "slug": "cash-register",
    "version": "1.0.0",
    "sdkVersion": "56.0.0",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "orientation": "portrait",
    "scheme": ["cashregister", "regkasse"],
    "userInterfaceStyle": "automatic",
    "primaryColor": "#2196F3",
    "backgroundColor": "#F5F5F5",
    "description": "RKSV Compliant Cash Register for Cashiers",
    "icon": "./assets/images/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.registrierkasse.cashregister",
      "buildNumber": "1",
      "backgroundColor": "#F5F5F5",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "192.168.1.2": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "192.168.1.100": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "192.168.0.100": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "10.0.0.100": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "172.20.10.1": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        }
      }
    },
    "android": {
      "package": "com.registrierkasse.cashregister",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F5F5F5"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5F5F5",
          "image": "./assets/images/adaptive-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#111827",
            "image": "./assets/images/adaptive-icon.png"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/OCRA-B.ttf"]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0"
          },
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Kamera wird für Kunden-QR und Gutschein-Scan benötigt.",
          "microphonePermission": false,
          "barcodeScannerEnabled": true,
          "recordAudioAndroid": false
        }
      ],
      "expo-sharing",
      "expo-secure-store",
      "expo-system-ui",
      [
        "expo-navigation-bar",
        {
          "enforceContrast": true,
          "hidden": false,
          "style": "dark"
        }
      ],
      [
        "expo-status-bar",
        {
          "hidden": true,
          "style": "dark"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "onDemandFilesystem": true
    }
  }
}
