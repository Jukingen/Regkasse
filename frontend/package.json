{
  "name": "cash-register",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --max-workers=2",
    "start:clean": "expo start --clear --max-workers=2",
    "android": "expo start --android --max-workers=2",
    "ios": "expo start --ios --max-workers=2",
    "web": "expo start --web --max-workers=2",
    "lint": "eslint .",
    "test": "jest",
    "test:contract": "jest __tests__/paymentService.taxTypeNormalization.test.ts __tests__/normalizePosPaymentMethods.test.ts __tests__/phaseDPaymentRequest.test.ts __tests__/posRegisterPaymentGate.test.ts __tests__/integration/api/payment-integration.test.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:debug": "jest --verbose --detectOpenHandles",
    "clean": "expo start --clear --reset-cache",
    "reset": "rm -rf node_modules && npm install && expo start --clear",
    "i18n:export-csv": "node ../localization/scripts/export-translations.mjs --app frontend",
    "i18n:import-csv": "node ../localization/scripts/import-translations.mjs --app frontend",
    "i18n:validate": "node ../localization/scripts/validate-translations.mjs --app frontend",
    "i18n:boundary": "node ../localization/scripts/check-translation-boundary.mjs --app frontend",
    "i18n:usage": "node ../localization/scripts/check-localization-usage.mjs --app frontend",
    "i18n:ci": "node ../localization/scripts/validate-translations.mjs --app frontend --strictMissing true --orphanPolicy error && node ../localization/scripts/check-translation-boundary.mjs --app frontend && node ../localization/scripts/check-localization-usage.mjs --app frontend --strictMissing true"
  },
