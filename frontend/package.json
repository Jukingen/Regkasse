{
  "name": "cash-register",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --max-workers=2",
    "start": "expo start --max-workers=2",
    "start:clean": "expo start --clear --max-workers=2",
    "android": "expo start --android --max-workers=2",
    "ios": "expo start --ios --max-workers=2",
    "web": "expo start --web --max-workers=2",
    "build": "expo export",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:contract": "jest __tests__/paymentService.taxTypeNormalization.test.ts __tests__/normalizePosPaymentMethods.test.ts __tests__/phaseDPaymentRequest.test.ts __tests__/posRegisterPaymentGate.test.ts __tests__/integration/api/payment-integration.test.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:debug": "jest --verbose --detectOpenHandles",
    "clean": "expo start --clear --reset-cache",
    "reset": "rm -rf node_modules && npm install && expo start --clear",
    "i18n:export-csv": "node ../localization/scripts/export-translations.mjs --app frontend",
    "i18n:import-csv": "node ../localization/scripts/import-translations.mjs --app frontend",
    "i18n:validate": "node ../localization/scripts/validate-translations.mjs --app frontend",
    "i18n:boundary": "node ../localization/scripts/check-translation-boundary.mjs --app frontend",
    "i18n:usage": "node ../localization/scripts/check-localization-usage.mjs --app frontend",
    "i18n:ci": "node ../localization/scripts/validate-translations.mjs --app frontend --strictMissing true --orphanPolicy error && node ../localization/scripts/check-translation-boundary.mjs --app frontend && node ../localization/scripts/check-localization-usage.mjs --app frontend --strictMissing true --budgetFile ../localization/i18n-ci-budgets.json"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "axios": "^1.18.1",
    "buffer": "^6.0.3",
    "expo": "~56.0.16",
    "expo-build-properties": "~56.0.23",
    "expo-camera": "~56.0.8",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.21",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.15",
    "expo-localization": "~56.0.6",
    "expo-navigation-bar": "~56.0.3",
    "expo-print": "~57.0.1",
    "expo-router": "~56.2.15",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.22",
    "expo-splash-screen": "~56.0.13",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "i18next": "^26.3.6",
    "intl-pluralrules": "^2.0.1",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.18.1",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.10",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-idle-timer-detection": "^1.0.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "29.5.14",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^9.39.5",
    "eslint-config-universe": "^16.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "prettier": "^3.9.6",
    "test-renderer": "^1.2.0",
    "ts-jest": "^29.4.11",
    "typescript": "~5.9.3"
  },
  "private": true
}
